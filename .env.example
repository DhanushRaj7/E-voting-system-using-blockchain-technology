# Copy to `.env` and fill in. NEVER commit real secrets.

# --- Frontend: RPC endpoint used by services/blockchain.ts fallback provider ---
# For local development this is the Hardhat node:
NEXT_APP_RPC_URL=http://127.0.0.1:8545

# --- CometChat (in-app chat) ---
# Create an app at https://www.cometchat.com/ and paste its credentials here.
# These are read in services/chat.ts.
NEXT_PUBLIC_COMET_CHAT_APP_ID=
NEXT_PUBLIC_COMET_CHAT_REGION=
NEXT_PUBLIC_COMET_CHAT_AUTH_KEY=
